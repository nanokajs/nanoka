{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // TODO(#110): "types" に "@cloudflare/workers-types" を追加することを検討する。
    //   e2e.workers.test.ts では D1Database 型が必要になる。
    //   ただし vitest-pool-workers が自動的に型を注入するケースもあるため、
    //   typecheck 時に型エラーが出る場合のみ追加する（過剰な型注入を避ける）。
    //   追加する場合: "types": ["node", "@cloudflare/workers-types"]
    "types": ["node"]
  },
  // TODO(#110): "include" の範囲を確認する。
  //   e2e.workers.test.ts は src/__tests__/ 配下に置くため "src/**/*" で既にカバーされる。
  //   test/migrations/0000_users.sql は .sql ファイルなので TypeScript の型チェック対象外であり変更不要。
  //   もし Workers 専用の型定義ファイルを src/__tests__/env.d.ts として分離する場合も
  //   "src/**/*" でカバーされるため include の追加は不要。
  "include": ["src/**/*"]
}
