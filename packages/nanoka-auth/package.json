{
  "name": "@nanokajs/auth",
  "version": "2.0.0",
  "type": "module",
  "description": "Authentication utilities for Nanoka on Cloudflare Workers.",
  "author": "Eiichiro Iriguchi <eiichiro_iriguchi@a-1ro.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nanokajs/nanoka.git"
  },
  "homepage": "https://github.com/nanokajs/nanoka#readme",
  "bugs": {
    "url": "https://github.com/nanokajs/nanoka/issues"
  },
  "keywords": [
    "nanoka",
    "auth",
    "cloudflare-workers",
    "hono",
    "d1"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run -c vitest.config.ts && vitest run -c vitest.node.config.ts",
    "test:workers": "vitest run -c vitest.config.ts",
    "test:node": "vitest run -c vitest.node.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test && pnpm typecheck"
  },
  "peerDependencies": {
    "@nanokajs/core": "^1.0.0 || ^2.0.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "^4.20260523.1",
    "@nanokajs/core": "workspace:*",
    "@types/node": "^25.9.1",
    "hono": "^4.12.22",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
