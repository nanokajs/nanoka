{
  "name": "@nanokajs/core",
  "version": "1.8.1",
  "type": "module",
  "description": "Thin wrapper over Hono + Drizzle + Zod for Cloudflare Workers + D1. 80% automatic, 20% explicit.",
  "author": "Eiichiro Iriguchi <eiichiro_iriguchi@a-1ro.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nanokajs/nanoka.git"
  },
  "homepage": "https://github.com/nanokajs/nanoka#readme",
  "bugs": {
    "url": "https://github.com/nanokajs/nanoka/issues"
  },
  "keywords": [
    "hono",
    "drizzle",
    "zod",
    "cloudflare-workers",
    "d1",
    "orm",
    "validation"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./turso": {
      "types": "./dist/turso.d.ts",
      "import": "./dist/turso.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "nanoka": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node ./scripts/prepend-shebang.mjs",
    "test": "vitest run -c vitest.config.ts && vitest run -c vitest.node.config.ts",
    "test:workers": "vitest run -c vitest.config.ts",
    "test:node": "vitest run -c vitest.node.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test && pnpm typecheck"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.0.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@libsql/client": {
      "optional": true
    }
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240925.0",
    "@libsql/client": "^0.14.0",
    "@types/node": "^25.6.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0",
    "zod": "^3.25.76"
  }
}
